APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Docker 例: リファラー・署名URLは APP_URL のホストに合わせる（localhost と 127.0.0.1 は別オリジン）
APP_URL=http://127.0.0.1:8080/billing

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Sanctum（同一オリジン API 利用時）。localhost と 127.0.0.1 は別ドメイン扱いのため両方記載
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# SMTP（例: dschatbot.ai 送信サーバ・認証必要）
MAIL_MAILER=smtp
MAIL_HOST=dschatbot.ai
MAIL_PORT=587
MAIL_USERNAME=admin-notify@dschatbot.ai
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=admin-notify@dschatbot.ai
MAIL_FROM_NAME="DSchatbot"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ROBOT PAYMENT（トークン方式 + 3DS2.0）
# ローカルで決済まで検証する場合: 店舗IDを設定し、決済システムCP（credit.j-payment.co.jp）で
# 「決済データ送信元IP」と「決済データ送信元URL」（APP_URL と一致させる。例: http://127.0.0.1:8080/billing）を登録すること。13_billing_robo_only_verification.md 参照。
ROBOTPAYMENT_ENABLED=false
# 店舗ID（6桁）。決済システムコントロールパネル（credit.j-payment.co.jp）で確認
ROBOTPAYMENT_STORE_ID=
# デモ等で発行されたAPI接続用アクセスキー（必要な場合のみ。リポジトリに実値は記載しないこと）
ROBOTPAYMENT_ACCESS_KEY=
ROBOTPAYMENT_GATEWAY_URL=https://credit.j-payment.co.jp/gateway/gateway_token.aspx
ROBOTPAYMENT_COMPANY_ID=1
# 決済結果通知URL（参照用）。ローカルは ngrok 等で公開URLを用意するか、通知はステージングで検証
ROBOTPAYMENT_NOTIFY_INITIAL_URL=
ROBOTPAYMENT_NOTIFY_RECURRING_URL=

# 請求管理ロボ API（API 1〜5）。09_demo_connection_billing_robo.md 参照
BILLING_ROBO_BASE_URL=https://demo.billing-robo.jp
BILLING_ROBO_USER_ID=
BILLING_ROBO_ACCESS_KEY=

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
